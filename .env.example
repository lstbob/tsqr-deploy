# Copy to .env and replace every CHANGE_ME value. .env is gitignored — never commit real secrets.

# PostgreSQL
POSTGRES_DB=tsqr_tool_library
POSTGRES_USER=tsqr
POSTGRES_PASSWORD=CHANGE_ME_strong_db_password

# Tool Library API connection string (must match the Postgres user/password above)
TOOL_LIB_CONNECTION=Host=postgres;Port=5432;Database=tsqr_tool_library;Username=tsqr;Password=CHANGE_ME_strong_db_password

# Shared JWT signing key for gateway + tool-lib (HMAC, must be >= 32 chars).
# Generate a random one, e.g.:  openssl rand -base64 48
JWT_KEY=CHANGE_ME_generate_a_random_key_at_least_32_chars

# Next.js UI -> gateway
API_URL=http://gateway:8080
